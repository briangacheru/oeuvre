# Oeuvre / iTasker configuration template.
# Copy this file to .env and fill in the real values. Do not commit .env.

# Application — keep false in production so errors are logged, not shown to users
APP_DEBUG=false
# Public base URL of the writer app (no trailing slash). Admin area is APP_URL/sudo.
APP_URL=https://your-domain.example

# Database
DB_HOST=localhost
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=tasker

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your_smtp_password
MAIL_FROM_ADDRESS=you@example.com
ADMIN_EMAIL=admin@example.com

# DigitalOcean Spaces
SPACES_REGION=sfo3
SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
SPACES_BUCKET=your_bucket
SPACES_KEY=your_spaces_key
SPACES_SECRET=your_spaces_secret
# Optional CDN endpoint, e.g. https://your_bucket.sfo3.cdn.digitaloceanspaces.com
# SPACES_CDN_ENDPOINT=
