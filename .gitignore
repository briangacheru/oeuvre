# Secrets / environment — never commit; use .env.example as the template
.env

# OS cruft
.DS_Store

# Logs
*.log

# Composer dependencies — single shared vendor/ for both interfaces, regenerate with `composer install`
# composer.lock IS tracked (pins exact versions) — do not ignore it
/vendor/

# User-uploaded runtime content (keep folder structure + hardening, not the data)
/profileimages/*
!/profileimages/1.jpg
!/profileimages/default.jpg
!/profileimages/.gitkeep
!/profileimages/.htaccess
/taskfiles/*
!/taskfiles/.gitkeep
!/taskfiles/.htaccess
/sudo/uploads/*
!/sudo/uploads/.htaccess
!/sudo/uploads/tasks/
/sudo/uploads/tasks/*
!/sudo/uploads/tasks/.gitkeep
